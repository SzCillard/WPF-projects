<Window x:Class="Food_Order.FoodEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Food_Order"
        mc:Ignorable="d"
        Title="FoodEditorWindow" Height="450" Width="800">
    <Grid>
        <StackPanel>
            <Label Content="Name" FontSize="16" Background="AliceBlue"/>
            <TextBox Text="{Binding Name}" FontSize="16"/>

            <Label Content="Type" FontSize="16" Background="AliceBlue"/>
            <ComboBox x:Name="cbox_type" Text="{Binding Type}" FontSize="16"/>

            <Label Content="Price" FontSize="16" Background="AliceBlue"/>
            <TextBox Text="{Binding Price}" FontSize="16"/>
            
            <Button Content="Save" FontSize="16" Click="Button_Click"/>
        </StackPanel>
    </Grid>
</Window>
